# OCR Provider: 'ocr_space' (recommended for Hindi/Sanskrit) or 'api_ninjas'
OCR_PROVIDER=ocr_space

# OCR.space API Key. Get a free key at https://ocr.space/ocrapi
# You can use 'helloworld' for low-rate testing.
OCR_SPACE_KEY=helloworld

# API Ninjas API Key (legacy, if you want to use it)
API_NINJAS_KEY=your_api_key_here

# Maximum size limit for image uploads in KB.
# OCR.space Free Tier limit: 1000 KB (1 MB)
# API Ninjas Free Tier limit: 200 KB
MAX_IMAGE_SIZE_KB=1000

# Google Gemini API Key. Get one from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI / Hugging Face API settings
OPENAI_API_BASE=https://router.huggingface.co/v1
OPENAI_API_KEY=your_huggingface_token_here
OPENAI_MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
